# Copie para .env (ou .env.local) e preencha. NUNCA commite esse arquivo (já ignorado via .env*).

# Postgres (Neon) — connection string com sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/essencial?sslmode=require"

# Auth.js v5
# Gere com: npx auth secret   (ou: openssl rand -base64 32)
AUTH_SECRET=""
# Em produção defina a URL pública; em dev pode omitir.
# AUTH_URL="http://localhost:3000"

# Armazenamento de fotos clínicas (Vercel Blob — ver docs/context/02-arquitetura.md)
BLOB_READ_WRITE_TOKEN=""

# IA (fase futura — não usada no MVP; ver docs/context/04-roadmap.md)
# GROQ_API_KEY=""

# Scheduler de lembretes (Vercel Cron, ver vercel.json e docs/context/04-roadmap.md).
# Gere com: openssl rand -base64 24   — configure o mesmo valor nas env vars do projeto na Vercel.
CRON_SECRET=""

# E-mail transacional (Brevo — brevo.com). O e-mail do remetente precisa estar verificado
# (domínio ou remetente único) no painel da Brevo antes de enviar de verdade — ver
# docs/context/04-roadmap.md. Sem essas duas variáveis, o envio de e-mail é pulado silenciosamente
# (o canal in-app continua funcionando normalmente).
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
# BREVO_SENDER_NOME="Essencial Centro"
