# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# claude code (config do projeto é versionada; overrides pessoais não)
.claude/settings.local.json

# vercel
.vercel

# material de referencia de design (terceiros, so consulta local, nunca comitar)
/docs/design-reference/
/pulkitxm claude-directory main templates-premium_tailgrids_dashspace/

# typescript
*.tsbuildinfo
next-env.d.ts
